# Copy to .env (do not commit .env). Pydantic reads UPPER_SNAKE_CASE env names.
#
# DATABASE_URL=sqlite:///./data/workbridge.db
# PUBLIC_BASE_URL=http://127.0.0.1:8000
# PORTAL_ADMIN_PASSWORD=change-me
# SUPER_ADMIN_PASSWORD=change-me
# GOOGLE_CREDENTIALS_PATH=google_key.json
# 매장별 용어(やさしい日本語) — 비우면 food-glossary·extra 시트만 사용
# SITE_GLOSSARY_SPREADSHEET_ID=
# SITE_GLOSSARY_SHEET_GID=0
# SITE_GLOSSARY_HEADER_ROW=1
# GCP에서 Cloud Translation API 활성화 필요 (언어 탭 번역)
